<Window x:Class="CleanupTemp_Pro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CleanupTemp Pro" Height="720" Width="980"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Icon="pack://application:,,,/app.ico"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="LowQuality">

    <Grid>
        <!-- Основной контейнер -->
        <Border Margin="14" CornerRadius="16"
                Background="{StaticResource DarkBgBrush}"
                BorderBrush="#1E1E4A" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="0" Opacity="0.7"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="32"/>
                </Grid.RowDefinitions>

                <!-- ═══════════════ TITLE BAR ═══════════════ -->
                <Border Grid.Row="0" CornerRadius="16,16,0,0"
                        MouseLeftButtonDown="TitleBar_MouseDown">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#0A0A20" Offset="0"/>
                            <GradientStop Color="#121230" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,1" EndPoint="1,1">
                            <GradientStop Color="#1A1A4A" Offset="0"/>
                            <GradientStop Color="#2A1A5A" Offset="0.5"/>
                            <GradientStop Color="#1A1A4A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>
                    <Border.BorderThickness>0,0,0,1</Border.BorderThickness>

                    <Grid Margin="14,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- LOGO + TITLE -->
                        <!-- ИСПРАВЛЕНО: Cursor="Hand" согласован с hover-событиями -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                    MouseEnter="TitleLogo_MouseEnter"
                                    MouseLeave="TitleLogo_MouseLeave"
                                    Cursor="Hand">
                            <Border Width="38" Height="38" Margin="0,0,10,0"
                                    SnapsToDevicePixels="True" UseLayoutRounding="True">
                                <!-- ИСПРАВЛЕНО: VisualBrush с RelativeToBoundingBox — маска масштабируется -->
                                <Border.OpacityMask>
                                    <VisualBrush Stretch="Fill"
                                                 ViewboxUnits="RelativeToBoundingBox"
                                                 ViewportUnits="RelativeToBoundingBox"
                                                 Viewbox="0,0,1,1" Viewport="0,0,1,1">
                                        <VisualBrush.Visual>
                                            <Border Width="38" Height="38" CornerRadius="10"
                                                    Background="Black"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.OpacityMask>
                                <!-- ИСПРАВЛЕНО: fallback Source на app.ico -->
                                <Image x:Name="TitleLogoImage"
                                       Width="38" Height="38"
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       SnapsToDevicePixels="True"
                                       UseLayoutRounding="True"
                                       Stretch="UniformToFill">
                                    <Image.Source>
                                        <BitmapImage UriSource="pack://application:,,,/app.ico"
                                                     CreateOptions="IgnoreImageCache"/>
                                    </Image.Source>
                                </Image>
                            </Border>

                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontFamily="Segoe UI Semibold" FontSize="15"
                                           Foreground="{StaticResource TextPrimaryBrush}">
                                    <Run Text="Cleanup" Foreground="White"/>
                                    <Run x:Name="TitleRunTemp" FontFamily="Segoe UI Light">
                                        <Run.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#4A9EFF" Offset="0"/>
                                                <GradientStop Color="#A855F7" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Run.Foreground>
                                        Temp
                                    </Run>
                                    <Run x:Name="TitleRunPro" Text=" Pro" Foreground="#06D6C7"
                                         FontFamily="Segoe UI Semibold"/>
                                </TextBlock>
                                <TextBlock Text="System Cleaner v.3.2.2.0"
                                           FontFamily="Segoe UI" FontSize="9"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- STATUS CENTER -->
                        <Border Grid.Column="1" HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#0A0A1E" CornerRadius="16" Padding="14,5"
                                BorderBrush="#2A2A4A" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="7" Height="7"
                                         Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="StatusDotColor" Color="#06D6C7"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock x:Name="StatusText" Text="Готов к работе"
                                           FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- WINDOW CONTROLS -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="О программе" Width="90" Height="26" FontSize="10"
                                    Cursor="Hand"
                                    Click="AboutBtn_Click"
                                    Style="{StaticResource TitleBarButton}"
                                    Margin="0,0,5,0" ToolTip="О программе"/>
                            <Button Content="−" Width="34" Height="26" FontSize="13"
                                    Cursor="Hand"
                                    Click="MinBtn_Click"
                                    Style="{StaticResource TitleBarButton}"
                                    ToolTip="Свернуть"/>
                            <Button Content="▢" Width="34" Height="26" FontSize="11"
                                    Cursor="Hand"
                                    Click="MaxBtn_Click"
                                    Style="{StaticResource TitleBarButton}"
                                    ToolTip="Развернуть"/>
                            <Button Content="✕" Width="34" Height="26" FontSize="12"
                                    Cursor="Hand"
                                    Click="CloseBtn_Click"
                                    Style="{StaticResource TitleBarCloseButton}"
                                    ToolTip="Закрыть"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
                <Grid Grid.Row="1" Margin="14,12,14,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ───── LEFT PANEL ───── -->
                    <Grid Grid.Column="0" Margin="0,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- DISK CARDS -->
                        <Border Grid.Row="0" CornerRadius="12" Padding="10,8" Margin="0,0,0,8"
                                MaxHeight="180"
                                Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="💽" FontSize="12" Margin="0,0,7,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Диски системы"
                                               FontFamily="Segoe UI Semibold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Style="{StaticResource ModernScrollViewer}">
                                    <ItemsControl x:Name="DisksPanel"/>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>

                        <!-- FOUND SIZE CARD -->
                        <Border Grid.Row="1" CornerRadius="12" Padding="14,10" Margin="0,0,0,8"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D1525" Offset="0"/>
                                    <GradientStop Color="#130D25" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A3A6A" Offset="0"/>
                                    <GradientStop Color="#3A1A6A" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <StackPanel>
                                <TextBlock Text="🗑️  Найдено мусора"
                                           FontFamily="Segoe UI Semibold" FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,0,3"/>
                                <TextBlock x:Name="TotalSizeText" Text="0 МБ"
                                           FontFamily="Segoe UI Light" FontSize="30"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock x:Name="FileCountText" Text="0 файлов"
                                           FontFamily="Segoe UI" FontSize="10"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- CATEGORIES -->
                        <Border Grid.Row="2" CornerRadius="12" Padding="12,10,12,8" Margin="0,0,0,8"
                                Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,6">
                                    <TextBlock Text="📂  Категории"
                                               FontFamily="Segoe UI Semibold" FontSize="12"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="Все" FontSize="10" Padding="7,2"
                                                Foreground="#4A9EFF" Background="#1A2A4A"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="SelectAll_Click"
                                                Style="{StaticResource GlowButton}"
                                                Margin="0,0,4,0"/>
                                        <Button Content="Сброс" FontSize="10" Padding="7,2"
                                                Foreground="#8888BB" Background="#1A1A3A"
                                                BorderThickness="0" Cursor="Hand"
                                                Click="SelectNone_Click"
                                                Style="{StaticResource GlowButton}"/>
                                    </StackPanel>
                                </Grid>
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              Style="{StaticResource ModernScrollViewer}">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkTempFiles"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="True" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="🗂️ "/><Run Text="Временные файлы"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkWinTemp"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="True" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="⚙️ "/><Run Text="Windows Temp"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkRecycleBin"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="True" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="🗑️ "/><Run Text="Корзина"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkBrowserCache"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="True" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="🌐 "/><Run Text="Кэш браузеров"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkThumbnails"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="True" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="🖼️ "/><Run Text="Thumbnails кэш"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkDnsCache"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="True" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="🔗 "/><Run Text="IE / Edge Cache"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkMSOffice"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="False" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="📎 "/><Run Text="Microsoft Office"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkPrefetch"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="False" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="⚡ "/><Run Text="Prefetch файлы"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkEventLogs"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="False" Margin="0,0,0,1"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="📋 "/><Run Text="Логи событий"/></TextBlock>
                                        </CheckBox>
                                        <CheckBox x:Name="ChkExternalDrives"
                                                  Style="{StaticResource ModernCheckBox}"
                                                  IsChecked="False" Margin="0,0,0,0"
                                                  Checked="Chk_Changed" Unchecked="Chk_Changed">
                                            <TextBlock><Run Text="💾 "/><Run Text="Диски D:, E:, флешки"/></TextBlock>
                                        </CheckBox>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- ACTION BUTTONS -->
                        <StackPanel Grid.Row="3">
                            <Border x:Name="ScanBtnBorder" CornerRadius="10" Height="40"
                                    Margin="0,0,0,6" Cursor="Hand"
                                    MouseLeftButtonDown="ScanBorder_Click"
                                    MouseEnter="ScanBorder_Enter"
                                    MouseLeave="ScanBorder_Leave">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5AABFF" Offset="0"/>
                                        <GradientStop Color="#2C52E0" Offset="0.5"/>
                                        <GradientStop Color="#8B3FFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#4A9EFF" BlurRadius="14" ShadowDepth="0" Opacity="0.5"/>
                                </Border.Effect>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#7BBFFF" Offset="0"/>
                                        <GradientStop Color="#9966FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🔍" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="СКАНИРОВАТЬ"
                                               FontFamily="Segoe UI Semibold" FontSize="13"
                                               FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CleanBtnBorder" CornerRadius="10" Height="40"
                                    Margin="0,0,0,6" Cursor="Hand" Opacity="0.8"
                                    MouseLeftButtonDown="CleanBorder_Click"
                                    MouseEnter="CleanBorder_Enter"
                                    MouseLeave="CleanBorder_Leave">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#E8405A" Offset="0"/>
                                        <GradientStop Color="#F07040" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#FF6080" Offset="0"/>
                                        <GradientStop Color="#FF9060" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1</Border.BorderThickness>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="🧹" FontSize="14" Foreground="White" Margin="0,0,8,0"/>
                                    <TextBlock Text="ОЧИСТИТЬ ВСЁ"
                                               FontFamily="Segoe UI Semibold" FontSize="13"
                                               FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="StopBtnBorder" CornerRadius="10" Height="40"
                                    BorderThickness="1"
                                    Cursor="Hand" Opacity="0.6"
                                    MouseLeftButtonDown="StopBorder_Click"
                                    MouseEnter="StopBorder_Enter"
                                    MouseLeave="StopBorder_Leave">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0A2A3A" Offset="0"/>
                                        <GradientStop Color="#0A2030" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#4A9EFF" Offset="0"/>
                                        <GradientStop Color="#06D6C7" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="⏹" FontSize="14" Margin="0,0,8,0">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#4A9EFF" Offset="0"/>
                                                <GradientStop Color="#06D6C7" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                    <TextBlock Text="ОСТАНОВИТЬ"
                                               FontFamily="Segoe UI Semibold" FontSize="13">
                                        <TextBlock.Foreground>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#4A9EFF" Offset="0"/>
                                                <GradientStop Color="#06D6C7" Offset="1"/>
                                            </LinearGradientBrush>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ───── RIGHT PANEL ───── -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- PROGRESS BAR -->
                        <Border Grid.Row="0" CornerRadius="12" Padding="16,12"
                                Margin="0,0,0,10"
                                Background="#13132B" BorderBrush="#252550"
                                BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,7">
                                    <TextBlock x:Name="ProgressLabel"
                                               Text="Ожидание сканирования..."
                                               FontFamily="Segoe UI" FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock x:Name="ProgressPercent"
                                               HorizontalAlignment="Right"
                                               FontFamily="Segoe UI Semibold" FontSize="11"
                                               Foreground="#4A9EFF"/>
                                </Grid>
                                <Border x:Name="ProgressBarContainer" Height="9"
                                        CornerRadius="4.5"
                                        Background="#0D0D20"
                                        BorderBrush="#1A1A3A" BorderThickness="1">
                                    <Border x:Name="ProgressBarFill"
                                            HorizontalAlignment="Left"
                                            Height="9" CornerRadius="4.5" Width="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#06D6C7" Offset="0"/>
                                                <GradientStop Color="#4A9EFF" Offset="0.45"/>
                                                <GradientStop Color="#A855F7" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- STAT CARDS -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" CornerRadius="12" Padding="14,11"
                                    Margin="0,0,8,0"
                                    Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🗂️" FontSize="17" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="StatTempFiles" Text="0"
                                               FontFamily="Segoe UI Light" FontSize="22"
                                               Foreground="#4A9EFF"/>
                                    <TextBlock Text="Temp файлов"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" CornerRadius="12" Padding="14,11"
                                    Margin="0,0,8,0"
                                    Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🌐" FontSize="17" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="StatBrowserFiles" Text="0"
                                               FontFamily="Segoe UI Light" FontSize="22"
                                               Foreground="#A855F7"/>
                                    <TextBlock Text="Кэш браузеров"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" CornerRadius="12" Padding="14,11"
                                    Margin="0,0,8,0"
                                    Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="🗑️" FontSize="17" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="StatRecycleBin" Text="0"
                                               FontFamily="Segoe UI Light" FontSize="22"
                                               Foreground="#FF4A6A"/>
                                    <TextBlock Text="В корзине"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="3" CornerRadius="12" Padding="14,11"
                                    Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="✅" FontSize="17" Margin="0,0,0,4"/>
                                    <TextBlock x:Name="StatCleaned" Text="0"
                                               FontFamily="Segoe UI Light" FontSize="22"
                                               Foreground="#06D6C7"/>
                                    <TextBlock Text="МБ очищено"
                                               FontFamily="Segoe UI" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- TABBED FILES / HISTORY -->
                        <Border Grid.Row="2" CornerRadius="12" Background="#0D0D1A"
                                BorderBrush="#252550" BorderThickness="1">
                            <!-- ИСПРАВЛЕНО: убран лишний вложенный Grid-обёртка,
                                 ChartOverlay и основной Grid — прямые дети одного Grid -->
                            <Grid>
                                <!-- CHART OVERLAY -->
                                <Grid x:Name="ChartOverlay" Visibility="Collapsed"
                                      Background="#0D0D1A">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                            Background="#13132B" BorderBrush="#252550"
                                            BorderThickness="0,0,0,1" Padding="12,0">
                                        <Grid Height="40">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border CornerRadius="6" Padding="7,3" Cursor="Hand"
                                                        Background="#1A2A4A"
                                                        MouseLeftButtonDown="ChartBack_Click"
                                                        MouseEnter="ChartBackBtn_Enter"
                                                        MouseLeave="ChartBackBtn_Leave">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="← " FontSize="11" Foreground="#4A9EFF"/>
                                                        <TextBlock Text="К результатам"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#4A9EFF"/>
                                                    </StackPanel>
                                                </Border>
                                                <TextBlock Text="📊  Отчёт по очистке"
                                                           FontFamily="Segoe UI Semibold" FontSize="12"
                                                           Foreground="#E8E8FF"
                                                           VerticalAlignment="Center" Margin="14,0,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" VerticalAlignment="Center">
                                            <Canvas x:Name="ChartCanvas" Width="160" Height="160"
                                                    HorizontalAlignment="Center"/>
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                <TextBlock x:Name="ChartTotalValue" Text="0"
                                                           FontFamily="Segoe UI Light" FontSize="20"
                                                           Foreground="#06D6C7"
                                                           HorizontalAlignment="Center"/>
                                                <TextBlock Text="ОЧИЩЕНО"
                                                           FontFamily="Segoe UI" FontSize="9"
                                                           Foreground="#555577"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Grid>

                                        <ScrollViewer Grid.Column="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Style="{StaticResource ModernScrollViewer}"
                                                      Margin="14,0,0,0">
                                            <ItemsControl x:Name="ChartLegend" VerticalAlignment="Center">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Padding="8,4" Margin="0,2"
                                                                CornerRadius="7"
                                                                Background="#13132B">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="10"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="65"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Ellipse Grid.Column="0"
                                                                         Width="7" Height="7"
                                                                         VerticalAlignment="Center"
                                                                         Fill="{Binding ColorBrush}"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Category}"
                                                                           FontFamily="Segoe UI" FontSize="11"
                                                                           Foreground="#C8C8EE"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Margin="7,0,5,0"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding PctText}"
                                                                           FontFamily="Segoe UI" FontSize="10"
                                                                           Foreground="#7070AA"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,5,0"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding SizeText}"
                                                                           FontFamily="Segoe UI Semibold" FontSize="11"
                                                                           Foreground="{Binding ColorBrush}"
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>

                                <!-- MAIN TABS GRID -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="40"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- TAB HEADERS -->
                                    <Border Grid.Row="0" CornerRadius="12,12,0,0"
                                            Background="#13132B"
                                            BorderBrush="#252550"
                                            BorderThickness="0,0,0,1">
                                        <Grid Margin="12,0">
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border x:Name="TabFilesHeader" CornerRadius="7"
                                                        Padding="12,5" Margin="0,0,5,0"
                                                        Background="#1A2A4A" Cursor="Hand"
                                                        MouseLeftButtonDown="TabFiles_Click"
                                                        MouseEnter="TabHeader_MouseEnter"
                                                        MouseLeave="TabHeader_MouseLeave">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📋 " FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="TabFilesText" Text="Файлы"
                                                                   FontFamily="Segoe UI Semibold" FontSize="11"
                                                                   Foreground="#4A9EFF" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border x:Name="TabHistoryHeader" CornerRadius="7"
                                                        Padding="12,5" Margin="0,0,5,0"
                                                        Background="Transparent" Cursor="Hand"
                                                        MouseLeftButtonDown="TabHistory_Click"
                                                        MouseEnter="TabHeader_MouseEnter"
                                                        MouseLeave="TabHeader_MouseLeave">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🕐 " FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="TabHistoryText" Text="История"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#8888BB" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border x:Name="TabLargeHeader" CornerRadius="7"
                                                        Padding="12,5" Margin="0,0,5,0"
                                                        Background="Transparent" Cursor="Hand"
                                                        MouseLeftButtonDown="TabLarge_Click"
                                                        MouseEnter="TabHeader_MouseEnter"
                                                        MouseLeave="TabHeader_MouseLeave">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📦 " FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="TabLargeText" Text="Большие файлы"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#8888BB" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border x:Name="TabExclusionsHeader" CornerRadius="7"
                                                        Padding="12,5"
                                                        Background="Transparent" Cursor="Hand"
                                                        MouseLeftButtonDown="TabExclusions_Click"
                                                        MouseEnter="TabHeader_MouseEnter"
                                                        MouseLeave="TabHeader_MouseLeave">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🛡️ " FontSize="11" VerticalAlignment="Center"/>
                                                        <TextBlock x:Name="TabExclusionsText" Text="Исключения"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#8888BB" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="ListCountLabel"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontFamily="Segoe UI" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Grid>
                                    </Border>

                                    <!-- TAB CONTENT -->
                                    <Grid Grid.Row="1">
                                        <!-- FILES TAB -->
                                        <ScrollViewer x:Name="FilesPanel"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      Style="{StaticResource ModernScrollViewer}"
                                                      Padding="7,5">
                                            <ListView x:Name="FileListView"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      VirtualizingPanel.IsVirtualizing="True"
                                                      VirtualizingPanel.VirtualizationMode="Recycling"
                                                      VirtualizingPanel.ScrollUnit="Item"
                                                      ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                      SelectionMode="Single"
                                                      Focusable="False">
                                                <ListView.ContextMenu>
                                                    <ContextMenu Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                                                        <MenuItem x:Name="MenuAddExclusion"
                                                                  Header="🛡️  Исключить из очистки"
                                                                  Click="AddExclusion_Click"
                                                                  Foreground="#E8E8FF"
                                                                  FontFamily="Segoe UI" FontSize="12"
                                                                  Background="Transparent"/>
                                                        <MenuItem x:Name="MenuAddFolderExclusion"
                                                                  Header="📁  Исключить всю папку"
                                                                  Click="AddFolderExclusion_Click"
                                                                  Foreground="#E8E8FF"
                                                                  FontFamily="Segoe UI" FontSize="12"
                                                                  Background="Transparent"/>
                                                    </ContextMenu>
                                                </ListView.ContextMenu>
                                                <ListView.ItemContainerStyle>
                                                    <Style TargetType="ListViewItem">
                                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                        <Setter Property="Padding" Value="0"/>
                                                        <Setter Property="Margin" Value="0"/>
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderThickness" Value="0"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="ListViewItem">
                                                                    <ContentPresenter/>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </ListView.ItemContainerStyle>
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,2" Padding="10,7"
                                                                CornerRadius="8"
                                                                Background="#13132B">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="22"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="100"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Icon}"
                                                                           FontSize="12"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Path}"
                                                                           FontFamily="Consolas" FontSize="11"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="7,0"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding Category}"
                                                                           FontFamily="Segoe UI" FontSize="10"
                                                                           Foreground="#7070AA"
                                                                           Margin="0,0,8,0"
                                                                           VerticalAlignment="Center"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding SizeText}"
                                                                           FontFamily="Segoe UI Semibold" FontSize="11"
                                                                           Foreground="#4A9EFF"
                                                                           VerticalAlignment="Center"
                                                                           HorizontalAlignment="Right"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </ScrollViewer>

                                        <!-- HISTORY TAB -->
                                        <ScrollViewer x:Name="HistoryPanel"
                                                      VerticalScrollBarVisibility="Auto"
                                                      Visibility="Collapsed"
                                                      Padding="7,5"
                                                      Style="{StaticResource ModernScrollViewer}">
                                            <ItemsControl x:Name="HistoryListView">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,2" Padding="14,10"
                                                                CornerRadius="8" Background="#13132B">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="28"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0"
                                                                           Text="{Binding Icon}"
                                                                           FontSize="14"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="1"
                                                                           Text="{Binding Date}"
                                                                           FontFamily="Segoe UI" FontSize="11"
                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="9,0"/>
                                                                <TextBlock Grid.Column="2"
                                                                           Text="{Binding FileCount}"
                                                                           FontFamily="Segoe UI" FontSize="11"
                                                                           Foreground="#8888BB"
                                                                           Margin="0,0,18,0"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Grid.Column="3"
                                                                           Text="{Binding Freed}"
                                                                           FontFamily="Segoe UI Semibold" FontSize="12"
                                                                           Foreground="#06D6C7"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>

                                        <!-- LARGE FILES TAB -->
                                        <Grid x:Name="LargeFilesPanel" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Margin="7,7,7,4"
                                                    Background="#13132B" CornerRadius="8"
                                                    BorderBrush="#252550" BorderThickness="1"
                                                    Padding="10,7">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="Минимальный размер:"
                                                               FontFamily="Segoe UI" FontSize="11"
                                                               Foreground="#8888BB"
                                                               VerticalAlignment="Center"
                                                               Margin="0,0,7,0"/>
                                                    <ComboBox x:Name="LargeSizeThreshold"
                                                              Grid.Column="1" Width="95"
                                                              FontFamily="Segoe UI" FontSize="11"
                                                              Background="#0D0D1A"
                                                              Foreground="#E8E8FF"
                                                              BorderBrush="#252550"
                                                              SelectedIndex="1">
                                                        <ComboBoxItem Content="100 МБ" Tag="104857600"/>
                                                        <ComboBoxItem Content="500 МБ" Tag="524288000"/>
                                                        <ComboBoxItem Content="1 ГБ"   Tag="1073741824"/>
                                                        <ComboBoxItem Content="2 ГБ"   Tag="2147483648"/>
                                                        <ComboBoxItem Content="5 ГБ"   Tag="5368709120"/>
                                                    </ComboBox>
                                                    <TextBlock x:Name="LargeFilesStatus"
                                                               Grid.Column="2"
                                                               FontFamily="Segoe UI" FontSize="11"
                                                               Foreground="#8888BB"
                                                               VerticalAlignment="Center"
                                                               Margin="10,0,0,0"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Column="3"
                                                            x:Name="LargeScanBtnBorder"
                                                            CornerRadius="6" Padding="12,4"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="LargeScan_Click"
                                                            MouseEnter="LargeScanBtn_Enter"
                                                            MouseLeave="LargeScanBtn_Leave">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#A855F7" Offset="0"/>
                                                                <GradientStop Color="#4A9EFF" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="🔍 " FontSize="11" Foreground="White"/>
                                                            <TextBlock Text="Найти"
                                                                       FontFamily="Segoe UI Semibold"
                                                                       FontSize="11" Foreground="White"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <ScrollViewer Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Style="{StaticResource ModernScrollViewer}"
                                                          Padding="7,4">
                                                <ListView x:Name="LargeFilesListView"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          VirtualizingPanel.IsVirtualizing="True"
                                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                                          VirtualizingPanel.ScrollUnit="Item"
                                                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                          SelectionMode="Single"
                                                          Focusable="False">
                                                    <ListView.ContextMenu>
                                                        <ContextMenu Background="#13132B" BorderBrush="#252550" BorderThickness="1">
                                                            <MenuItem Header="📂  Открыть папку"
                                                                      Click="LargeFile_OpenFolder"
                                                                      Foreground="#E8E8FF"
                                                                      FontFamily="Segoe UI" FontSize="12"
                                                                      Background="Transparent"/>
                                                            <MenuItem Header="🗑️  Удалить файл"
                                                                      Click="LargeFile_Delete"
                                                                      Foreground="#FF4A6A"
                                                                      FontFamily="Segoe UI" FontSize="12"
                                                                      Background="Transparent"/>
                                                        </ContextMenu>
                                                    </ListView.ContextMenu>
                                                    <ListView.ItemContainerStyle>
                                                        <Style TargetType="ListViewItem">
                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                            <Setter Property="Padding" Value="0"/>
                                                            <Setter Property="Margin" Value="0"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListViewItem">
                                                                        <ContentPresenter/>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListView.ItemContainerStyle>
                                                    <ListView.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,2" Padding="10,8"
                                                                    CornerRadius="8" Background="#13132B">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="22"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="85"/>
                                                                        <ColumnDefinition Width="75"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Icon}"
                                                                               FontSize="12"
                                                                               VerticalAlignment="Center"/>
                                                                    <StackPanel Grid.Column="1" Margin="7,0">
                                                                        <TextBlock Text="{Binding FileName}"
                                                                                   FontFamily="Segoe UI Semibold"
                                                                                   FontSize="11"
                                                                                   Foreground="#E8E8FF"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Path}"
                                                                                   FontFamily="Consolas" FontSize="10"
                                                                                   Foreground="#7070AA"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding Category}"
                                                                               FontFamily="Segoe UI" FontSize="10"
                                                                               Foreground="#7070AA"
                                                                               VerticalAlignment="Center"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Margin="0,0,5,0"/>
                                                                    <TextBlock Grid.Column="3"
                                                                               Text="{Binding SizeText}"
                                                                               FontFamily="Segoe UI Semibold" FontSize="12"
                                                                               Foreground="#FF8C00"
                                                                               VerticalAlignment="Center"
                                                                               HorizontalAlignment="Right"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ListView.ItemTemplate>
                                                </ListView>
                                            </ScrollViewer>
                                        </Grid>

                                        <!-- EXCLUSIONS TAB -->
                                        <Grid x:Name="ExclusionsPanel" Visibility="Collapsed">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0" Margin="7,7,7,4"
                                                    Background="#13132B" CornerRadius="8"
                                                    BorderBrush="#252550" BorderThickness="1"
                                                    Padding="10,7">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                               Text="Файлы и папки в этом списке никогда не будут удалены"
                                                               FontFamily="Segoe UI" FontSize="11"
                                                               Foreground="#8888BB"
                                                               VerticalAlignment="Center"/>
                                                    <Border Grid.Column="1"
                                                            x:Name="AddExclusionManualBtn"
                                                            CornerRadius="6" Padding="10,4"
                                                            Cursor="Hand" Margin="0,0,5,0"
                                                            MouseLeftButtonDown="AddExclusionManual_Click"
                                                            MouseEnter="ExclusionBtn_Enter"
                                                            MouseLeave="ExclusionBtn_Leave">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#1A2A4A" Offset="0"/>
                                                                <GradientStop Color="#1A1A3A" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border.BorderBrush>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#4A9EFF" Offset="0"/>
                                                                <GradientStop Color="#A855F7" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.BorderBrush>
                                                        <Border.BorderThickness>1</Border.BorderThickness>
                                                        <TextBlock Text="+ Добавить путь"
                                                                   FontFamily="Segoe UI Semibold"
                                                                   FontSize="11" Foreground="#4A9EFF"/>
                                                    </Border>
                                                    <Border Grid.Column="2"
                                                            x:Name="ClearExclusionsBtn"
                                                            CornerRadius="6" Padding="10,4"
                                                            Cursor="Hand"
                                                            MouseLeftButtonDown="ClearExclusions_Click"
                                                            MouseEnter="ExclusionBtn_Enter"
                                                            MouseLeave="ExclusionBtn_Leave"
                                                            Background="#1A0A0A"
                                                            BorderBrush="#3A1A1A"
                                                            BorderThickness="1">
                                                        <TextBlock Text="🗑 Очистить всё"
                                                                   FontFamily="Segoe UI Semibold"
                                                                   FontSize="11" Foreground="#FF4A6A"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <ScrollViewer Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          Style="{StaticResource ModernScrollViewer}"
                                                          Padding="7,4">
                                                <ItemsControl x:Name="ExclusionsListView">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Margin="0,2" Padding="10,7"
                                                                    CornerRadius="8" Background="#13132B">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="22"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Icon}"
                                                                               FontSize="12"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Path}"
                                                                               FontFamily="Consolas" FontSize="11"
                                                                               Foreground="#C8C8EE"
                                                                               VerticalAlignment="Center"
                                                                               Margin="7,0"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding Path}"/>
                                                                    <Border Grid.Column="2"
                                                                            CornerRadius="5" Padding="7,3"
                                                                            Cursor="Hand"
                                                                            Tag="{Binding Path}"
                                                                            MouseLeftButtonDown="RemoveExclusion_Click"
                                                                            Background="#2A0A0A"
                                                                            BorderBrush="#3A1010"
                                                                            BorderThickness="1">
                                                                        <TextBlock Text="✕"
                                                                                   FontSize="10"
                                                                                   Foreground="#FF4A6A"/>
                                                                    </Border>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ═══════════════ STATUS BAR ═══════════════ -->
                <Border Grid.Row="2" CornerRadius="0,0,16,16"
                        Background="#0A0A18" BorderBrush="#1A1A3A"
                        BorderThickness="0,1,0,0">
                    <Grid Margin="18,0">
                        <TextBlock Text="CleanupTemp Pro v.3.2.2.0  •  Запускайте от имени администратора для полной очистки"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#3A3A6A" VerticalAlignment="Center"/>
                        <TextBlock Text="© 2026 CleanupTemp Pro"
                                   HorizontalAlignment="Right"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#3A3A6A" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- BG GLOW ORBS — ИСПРАВЛЕНО: привязаны к размеру через RelativePanel,
                     используем Canvas с ClipToBounds и относительным позиционированием -->
                <Canvas Grid.RowSpan="3" IsHitTestVisible="False" ClipToBounds="True">
                    <Ellipse Canvas.Left="-160" Canvas.Top="-160"
                             Width="420" Height="420" Opacity="0.10">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#4A9EFF" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse Canvas.Right="0" Canvas.Bottom="0"
                             Width="500" Height="500" Opacity="0.11">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Canvas>

            </Grid>
        </Border>
    </Grid>
</Window>
