<Window x:Class="CleanupTemp_Pro.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="Transparent"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize"
        Icon="pack://application:,,,/app.ico"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <!-- Тень через слои Border — без DropShadowEffect -->
    <Grid>
        <Border Margin="12" CornerRadius="22" Background="#55000000" IsHitTestVisible="False"/>
        <Border Margin="9"  CornerRadius="20" Background="#44000000" IsHitTestVisible="False"/>
        <Border Margin="6"  CornerRadius="19" Background="#33000000" IsHitTestVisible="False"/>

        <!-- Основной контейнер -->
        <Border Margin="4" CornerRadius="18" BorderThickness="1">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#3A4A8A" Offset="0"/>
                    <GradientStop Color="#4A2A8A" Offset="0.5"/>
                    <GradientStop Color="#2A4A70" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#080812" Offset="0"/>
                    <GradientStop Color="#0C0C1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Кнопка закрыть — верхний уровень Grid, без ZIndex -->
                <Border x:Name="CloseBtnBorder"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="28" Height="28" Margin="0,10,10,0"
                        CornerRadius="7" Background="Transparent"
                        BorderBrush="Transparent" BorderThickness="1"
                        Cursor="Hand"
                        MouseLeftButtonDown="CloseBorder_Click"
                        MouseEnter="CloseBorder_Enter"
                        MouseLeave="CloseBorder_Leave">
                    <TextBlock Text="✕" FontSize="12"
                               FontFamily="Segoe UI"
                               Foreground="#FF4A6A"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center" Margin="28,40,28,24">

                    <!-- Логотип -->
                    <Border x:Name="LogoBorder"
                            HorizontalAlignment="Center" Margin="0,0,0,16"
                            Width="96" Height="96"
                            CornerRadius="24" BorderThickness="2"
                            SnapsToDevicePixels="True" UseLayoutRounding="True"
                            MouseEnter="Logo_MouseEnter"
                            MouseLeave="Logo_MouseLeave"
                            Cursor="Hand">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4A9EFF" Offset="0"/>
                                <GradientStop Color="#B06EFF" Offset="0.5"/>
                                <GradientStop Color="#00E5D0" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>
                        <Border.Background>
                            <SolidColorBrush Color="Transparent"/>
                        </Border.Background>
                        <Border CornerRadius="21"
                                SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Border.OpacityMask>
                                <VisualBrush Stretch="Fill"
                                             ViewboxUnits="RelativeToBoundingBox"
                                             ViewportUnits="RelativeToBoundingBox"
                                             Viewbox="0,0,1,1" Viewport="0,0,1,1">
                                    <VisualBrush.Visual>
                                        <Border Width="90" Height="90"
                                                CornerRadius="21" Background="Black"/>
                                    </VisualBrush.Visual>
                                </VisualBrush>
                            </Border.OpacityMask>
                            <Image x:Name="LogoImage"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   SnapsToDevicePixels="True"
                                   UseLayoutRounding="True"
                                   Stretch="UniformToFill">
                                <Image.Source>
                                    <BitmapImage UriSource="pack://application:,,,/app.ico"
                                                 CreateOptions="IgnoreImageCache"/>
                                </Image.Source>
                            </Image>
                        </Border>
                    </Border>

                    <!-- Title -->
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,3"
                               MouseEnter="Title_MouseEnter"
                               MouseLeave="Title_MouseLeave"
                               Cursor="Hand">
                        <Run x:Name="AboutRunCleanup"
                             Text="CleanupTemp "
                             FontFamily="Segoe UI Semibold"
                             FontSize="22" Foreground="#E8E8FF"/>
                        <Run x:Name="AboutRunPro"
                             Text="Pro"
                             FontFamily="Segoe UI Semibold" FontSize="22">
                            <Run.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#5ABAFF" Offset="0"/>
                                    <GradientStop Color="#B06EFF" Offset="0.5"/>
                                    <GradientStop Color="#00E5D0" Offset="1"/>
                                </LinearGradientBrush>
                            </Run.Foreground>
                        </Run>
                    </TextBlock>

                    <TextBlock Text="Версия 3.2.2.0"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#6060C0"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <!-- Divider 1 -->
                    <Border Height="1" Margin="0,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#2A2A6A" Offset="0.2"/>
                                <GradientStop Color="#4A9EFF" Offset="0.4"/>
                                <GradientStop Color="#B06EFF" Offset="0.6"/>
                                <GradientStop Color="#2A2A6A" Offset="0.8"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Feature list -->
                    <StackPanel Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                            <Border Width="24" Height="24" CornerRadius="7" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1A3A80" Offset="0"/>
                                        <GradientStop Color="#3A1A70" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🔍" FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Автоматическое сканирование 9 категорий"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#B8B8E0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                            <Border Width="24" Height="24" CornerRadius="7" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#450A20" Offset="0"/>
                                        <GradientStop Color="#6A1A30" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🧹" FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Глубокая очистка + корзина Windows"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#B8B8E0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,7">
                            <Border Width="24" Height="24" CornerRadius="7" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#083028" Offset="0"/>
                                        <GradientStop Color="#105A40" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="🌐" FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Chrome, Edge, Firefox, Brave, Yandex"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#B8B8E0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24" Height="24" CornerRadius="7" Margin="0,0,10,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#302808" Offset="0"/>
                                        <GradientStop Color="#504010" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="📊" FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="История очисток и статистика"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#B8B8E0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider 2 -->
                    <Border Height="1" Margin="0,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#1A1A3A" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <TextBlock Text="© 2026 CleanupTemp Pro. Все права защищены."
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#484870"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Запускайте от имени администратора для полной очистки"
                               FontFamily="Segoe UI" FontSize="10"
                               Foreground="#484870"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Виталий Николаевич (vitalikkontr)"
                               FontFamily="Segoe UI" FontSize="11"
                               Foreground="#484870"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
